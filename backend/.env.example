# Required: OpenAI API key for GenAI image generation and GPT translations
OPENAI_API_KEY=sk-...your-key-here...

# Optional: Server port (default: 3001)
PORT=3001

# example values: cover inside outside contain fill
SHARP_RESIZE_FIT=cover

# example values: gpt-image-1 dall-e-3
GEN_AI_MODEL=gpt-image-1
